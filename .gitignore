backups/

# --- Logs ---
*.log
logs/

# --- Databases ---
*.sqlite3
*.db
*.db-journal

# --- Archives ---
*.tar.gz

# --- Env files (CRITICAL: keep .env.example tracked) ---
.env
.env.*
*.env
!.env.example

# --- Credentials / secrets (CRITICAL — must be ignored everywhere) ---
token.json
credentials.json
apikey.json
jsons/
