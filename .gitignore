# --- Aider ---
.aider.chat.history.md
.aider.input.history
.aider.tags.cache.v4/
.aider.conf.yml.bak

# --- Worktrees / scratch ---
worktrees/
jules-scratch/
jules_sessions/*_activities.json
diagnosis_message.txt
app_output.log
isolated_ui.log

# --- Test duplicates ---
tests/modules/*_fixed.sh
tests/modules/*_fixed*.sh
tests/modules/*_final.sh

# --- Branch-specific data (whitelist intentional configs) ---
!docs/.branch-config.json
!docs/.review-queue.json
!docs/.merge-history.json

# --- Tooling configs that ARE intentionally committed ---
!.pre-commit-config.yaml
!.prettierrc.json
!.eslintrc.json
!.github/
!.github/workflows/
!client/.eslintrc.json
!/server/.eslintrc.json
!.env.example

# === Branch-specific exceptions (Phase 14) ===
# Document each entry: who added, why, when.
# These patterns are specific to the main branch and not part of the unified baseline.

# --- Hidden files blanket (main convention) ---
# Main uses a catch-all for dot-dirs with explicit exceptions.
# This MUST come after the unified baseline so baseline patterns take precedence.
.*
!.gitignore
!.semgrep/
!.flake8
!.pylintrc
!.mergify.yml
!.gitattributes
!.gitmodules
!.pre-commit-config.yaml
!.prettierrc.json
!.eslintrc.json
!.github/
!.github/workflows/
!client/.eslintrc.json
!/server/.eslintrc.json
!.env.example
!.context-control/
!docs/.gitkeep
!docs/.branch-config.json
!docs/.review-queue.json
!docs/.merge-history.json

