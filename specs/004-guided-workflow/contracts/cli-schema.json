{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OrchestrationCoreCLIOutput",
  "type": "object",
  "properties": {
    "version": { "type": "string" },
    "command": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "status": {
      "type": "string",
      "enum": ["success", "error", "warning"]
    },
    "data": { "type": "object" },
    "error": {
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "details": { "type": "string" },
        "hint": { "type": "string" }
      },
      "required": ["code", "message"]
    }
  },
  "required": ["version", "command", "status"]
}
