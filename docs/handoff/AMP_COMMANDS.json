{
  "amp_commands": {
    "phase_0": {
      "mode": "rush",
      "description": "Bootstrap Agent Rules content from agentrulegen.com",
      "skills": ["agent-rules-handoff"]
    },
    "phase_1": {
      "mode": "rush",
      "phase_doc": "docs/handoff/phase-01-emergency-fixes.md",
      "steps": 13,
      "skills": ["branch-isolation-guard", "tool-ecosystem-manager"]
    },
    "phase_2": {
      "mode": "rush", 
      "phase_doc": "docs/handoff/phase-02-content-fixes.md",
      "steps": 8,
      "skills": ["agent-resource-manager", "ast-grep"]
    },
    "phase_3": {
      "mode": "rush",
      "phase_doc": "docs/handoff/phase-03-ruler-setup.md", 
      "steps": 6,
      "skills": ["agent-rules-handoff", "tool-ecosystem-manager"]
    },
    "phase_4": {
      "mode": "rush",
      "phase_doc": "docs/handoff/phase-04-agent-rulez.md",
      "steps": 6,
      "binary": "rulez (use system install, NOT /tmp/rulez)"
    },
    "gate_check": {
      "mode": "deep",
      "skills": ["branch-isolation-guard", "tool-ecosystem-manager"]
    },
    "error_recovery": {
      "mode": "deep",
      "skills": ["serena-mcp-agent", "coding-agent"]
    },
    "review_process": {
      "mode": "deep",
      "description": "Spawn for gate check failures, verification failures, or architectural decisions",
      "skills": ["branch-isolation-guard", "tool-ecosystem-manager", "serena-mcp-agent", "coding-agent"]
    }
  },
  "skills_directories": {
    "letta": "~/.letta/skills/",
    "agents": "~/.agents/skills/",
    "project": ".agents/skills/"
  },
  "subagents": {
    "serena": {
      "purpose": "Semantic code search (30x token reduction)",
      "location": "~/.agents/skills/serena-mcp-agent/SKILL.md"
    },
    "coding_agent": {
      "purpose": "Second opinion, parallel verification",
      "tools": ["codex", "claude", "opencode", "pi"]
    },
    "gemini": {
      "purpose": "Parallel verification",
      "location": "~/.agents/skills/gemini/SKILL.md"
    }
  },
  "mcp_servers": {
    "task-master-ai": {
      "command": "npm exec task-master-ai",
      "env": ["GOOGLE_API_KEY", "GEMINI_API_KEY", "GITHUB_API_KEY"]
    },
    "ck": {
      "command": "ck --serve",
      "purpose": "Semantic code search"
    }
  }
}
