{
  "amp_commands": {
    "phase_0": {
      "mode": "rush",
      "description": "Bootstrap Agent Rules content from agentrulegen.com",
      "skills": ["agent-rules-handoff"]
    },
    "phase_1": {
      "mode": "rush", 
      "phase_doc": "docs/handoff/phase-01-emergency-fixes.md",
      "steps": 13,
      "skills": ["branch-isolation-guard", "tool-ecosystem-manager"]
    },
    "phase_2": {
      "mode": "rush",
      "phase_doc": "docs/handoff/phase-02-content-fixes.md", 
      "steps": 8,
      "skills": ["agent-resource-manager", "ast-grep"]
    },
    "phase_3": {
      "mode": "rush",
      "phase_doc": "docs/handoff/phase-03-ruler-setup.md", 
      "steps": 6,
      "skills": ["agent-rules-handoff", "tool-ecosystem-manager"]
    },
    "phase_4": {
      "mode": "rush",
      "phase_doc": "docs/handoff/phase-04-agent-rulez.md",
      "steps": 6,
      "binary": "rulez (use system install, NOT /tmp/rulez)"
    },
    "gate_check": {
      "mode": "deep",
      "skills": ["branch-isolation-guard", "tool-ecosystem-manager"],
      "native_tools": ["oracle", "librarian"]
    },
    "error_recovery": {
      "mode": "deep",
      "skills": ["serena-mcp-agent", "coding-agent"],
      "native_tools": ["oracle", "librarian", "subagents"]
    },
    "review_process": {
      "mode": "deep",
      "description": "Spawn for gate check failures, verification failures, or architectural decisions",
      "skills": ["branch-isolation-guard", "tool-ecosystem-manager", "serena-mcp-agent", "coding-agent"],
      "native_tools": ["oracle", "librarian", "subagents", "amp review"]
    }
  },
  "native_amp_tools": {
    "oracle": {
      "model": "GPT-5.4 with high reasoning",
      "purpose": "Second opinion for complex analysis, architecture decisions, deep debugging",
      "usage": "Direct prompt: 'Use the oracle to review...'"
    },
    "librarian": {
      "purpose": "Search remote codebases (GitHub, Bitbucket)",
      "usage": "Direct prompt: 'Use the Librarian to search...'",
      "requires": ["GitHub connection in settings OR amp.bitbucketToken"]
    },
    "subagents": {
      "tool": "Task",
      "purpose": "Parallel work, independent execution, context isolation",
      "limitations": ["Cannot communicate mid-task", "Start fresh without context", "Main agent gets summary only"]
    },
    "painter": {
      "model": "Gemini 3 Pro Image",
      "purpose": "UI mockups, app icons, redacting sensitive info from screenshots"
    },
    "amp_review": {
      "command": "amp review",
      "purpose": "Code review for bugs, security, performance, style",
      "checks_dir": ".agents/checks/"
    }
  },
  "skills_directories": {
    "user_global": "~/.config/agents/skills/",
    "amp_global": "~/.config/amp/skills/",
    "project": ".agents/skills/",
    "claude_project": ".claude/skills/",
    "claude_global": "~/.claude/skills/",
    "letta": "~/.letta/skills/"
  },
  "mcp_servers": {
    "task-master-ai": {
      "command": "npm exec task-master-ai",
      "env": ["GOOGLE_API_KEY", "GEMINI_API_KEY", "GITHUB_API_KEY"]
    },
    "ck": {
      "command": "ck --serve",
      "purpose": "Semantic code search"
    }
  }
}
