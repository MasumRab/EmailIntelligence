# =====================================================================
# Unified .gitignore — canonical baseline for all EmailIntelligence branches
# Generated from union of: main, scientific, orchestration-tools, taskmaster
# =====================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
*.whl
MANIFEST
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# --- Virtualenvs ---
venv/
.venv/
env/
.python-version

# --- Test / coverage ---
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Node / frontend ---
node_modules/
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.npm-*
client/dist/
server/public/
vite.config.ts.*

# --- OS / editor ---
.DS_Store
Thumbs.db
*.swp
*~

# --- Backups ---
*.bak
backups/

# --- Logs ---
*.log
logs/

# --- Databases ---
*.sqlite3
*.db
*.db-journal

# --- Archives ---
*.tar.gz

# --- Env files (CRITICAL: keep .env.example tracked) ---
.env
.env.*
*.env
!.env.example

# --- Credentials / secrets (CRITICAL — must be ignored everywhere) ---
token.json
credentials.json
apikey.json
jsons/
config/llm_guidelines.local.json

# --- Aider ---
.aider.chat.history.md
.aider.input.history
.aider.tags.cache.v4/
.aider.conf.yml.bak

# --- Worktrees / scratch ---
worktrees/
jules-scratch/
jules_sessions/*_activities.json
diagnosis_message.txt
app_output.log
isolated_ui.log

# --- Test duplicates ---
tests/modules/*_fixed.sh
tests/modules/*_fixed*.sh
tests/modules/*_final.sh

# --- Branch-specific data (whitelist intentional configs) ---
!docs/.branch-config.json
!docs/.review-queue.json
!docs/.merge-history.json

# --- Tooling configs that ARE intentionally committed ---
!.pre-commit-config.yaml
!.prettierrc.json
!.eslintrc.json
!.github/
!.github/workflows/
!client/.eslintrc.json
!/server/.eslintrc.json
!.env.example
